{
  "name": "fella-cli",
  "version": "1.0.8",
  "description": "File Exploration and Local Logic Automation — An AI-powered agentic CLI for Windows",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/index.js",
    "dist/package.json",
    "README.md",
    "assets/FELLA_CAT.ico",
    "assets/FELLA_CAT.png",
    "assets/logo.png"
  ],
  "bin": {
    "fella": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Deepakchandrasekar05/FELLA.git"
  },
  "homepage": "https://github.com/Deepakchandrasekar05/FELLA#readme",
  "bugs": {
    "url": "https://github.com/Deepakchandrasekar05/FELLA/issues"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "file-manager",
    "terminal",
    "automation",
    "windows",
    "llm",
    "groq",
    "ink",
    "natural-language"
  ],
  "author": "Deepakchandrasekar05",
  "license": "ISC",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "bundle": "node scripts/bundle.mjs",
    "postbundle": "node scripts/postbundle.mjs",
    "build": "npm run typecheck && npm run bundle && npm run postbundle",
    "prepublishOnly": "npm run build",
    "predist": "node scripts/predist.mjs",
    "sea": "npm run build && node scripts/sea.mjs",
    "caxa:win": "npm run build && caxa --no-dedupe --input dist --output bin/fella-win.exe -- \"{{caxa}}/node.exe\" \"{{caxa}}/run.cjs\"",
    "caxa:linux": "npm run build && caxa --input dist --output bin/fella-linux -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/index.js\"",
    "caxa:mac": "npm run build && caxa --input dist --output bin/fella-macos -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/index.js\"",
    "dist": "taskkill /F /IM fella-win.exe 2>nul & npm run build && npm run predist && caxa --no-dedupe --input dist --output bin/fella-win.exe --stub dist/fella-stub.exe -- \"{{caxa}}/node.exe\" \"{{caxa}}/run.cjs\"",
    "desktop:build": "node scripts/bundle-desktop.mjs",
    "desktop:dev": "node scripts/bundle-desktop.mjs && electron desktop-dist/main.js",
    "desktop:start": "electron desktop-dist/main.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@playwright/mcp": "^0.0.68",
    "@supabase/supabase-js": "^2.98.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "chrome-devtools-mcp": "^0.20.3",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.27.0",
    "playwright": "^1.55.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "trash": "^10.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "canvas": "^3.2.1",
    "caxa": "^3.0.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "rcedit": "^1.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
